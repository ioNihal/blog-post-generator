# Required
GEMINI_API_KEY=your_gemini_api_key
GH_USERNAME=your_github_username

# Optional - GitHub token for higher rate limits and private repo access
GITHUB_TOKEN=

# Optional - Gemini model to use (default: gemini-2.5-flash)
GEMINI_MODEL=gemini-2.5-flash

# Optional - output directory for generated .mdx files (default: ./generated)
OUTPUT_DIR=./generated

# Optional - comma-separated repo names to exclude from commit collection
IGNORED_REPOS=daily-blog-generator

# Optional - commits containing this keyword are skipped (default: [skip-log])
SKIP_KEYWORD=[skip-log]
